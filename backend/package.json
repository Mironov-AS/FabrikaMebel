{
  "name": "contract-management-api",
  "version": "1.0.0",
  "description": "Backend API for Contract Management System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^../db$": "<rootDir>/src/__tests__/dbmock.js",
      "^./db$": "<rootDir>/src/__tests__/dbmock.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "better-sqlite3": "^12.9.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
